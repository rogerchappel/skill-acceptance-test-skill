{
  "name": "skill-acceptance-test-skill",
  "version": "0.1.0",
  "description": "Local-first acceptance checks for reusable agent skills.",
  "type": "module",
  "bin": {
    "skill-acceptance-test": "./src/cli.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/cli.js && node --check src/index.js",
    "smoke": "node src/cli.js --skill fixtures/sample-skill/SKILL.md --contract fixtures/contract.json --fixtures fixtures/sample-skill/fixtures --format markdown",
    "validate": "bash scripts/validate.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run validate && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "acceptance-test",
    "fixtures",
    "release-readiness"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/skill-acceptance-test-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/skill-acceptance-test-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/skill-acceptance-test-skill#readme",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src",
    "docs",
    "examples",
    "fixtures",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ]
}
